# ---------------------------------------------------------------------------
# Validation artifacts policy: version ONLY the experiments that reflect the
# CURRENT state of the code (the certified bundles, the certification record,
# and the generated-references feature proof). Every other experiment stays
# local for the team but is not versioned.
# ---------------------------------------------------------------------------
artifacts/*
!artifacts/validation/
artifacts/validation/*

# Golden-bake regression harness output: version the summaries and
# profiles (small, reviewable); the baked bytes are hash-identical
# duplicates of the certified assets and stay local.
!artifacts/validation/golden-bake/
artifacts/validation/golden-bake/**/scene.glb
artifacts/validation/golden-bake/**/texture.png
artifacts/validation/golden-bake/**/uv_preview.png
artifacts/validation/golden-bake/**/profile.json

# Bake performance program proof pack (charts, identity sheets, report)
!artifacts/validation/bake-performance-program/

# Quality-review protocol output (renders, structural data, scores)
!artifacts/validation/quality-review/

# Certified proof assets (current pipeline output)
!artifacts/validation/final-proof/
artifacts/validation/final-proof/*
!artifacts/validation/final-proof/hunyuan-starship/
!artifacts/validation/final-proof/hunyuan-owl/
!artifacts/validation/final-proof/summary/
!artifacts/validation/iter3-multiview-fixed/
artifacts/validation/iter3-multiview-fixed/*
!artifacts/validation/iter3-multiview-fixed/face-2mv/
# Parity canary fixture (scripts/parity_canary.py): the pinned rebake
# inputs + reference texture must be versioned or the canary is mute.
!artifacts/validation/parity/

# Generated-reference views feature (current)
!artifacts/validation/generated-references/

# Certification record + key evidence (current)
!artifacts/validation/texture-cycle-proofs/
artifacts/validation/texture-cycle-proofs/qa_runs/
artifacts/validation/texture-cycle-proofs/critic1_evidence_sheets/
artifacts/validation/texture-cycle-proofs/meshvault/**/*.png

# Heavy sidecars excluded from versioned bundles (regenerable from scene.glb)
artifacts/validation/**/scene.obj
artifacts/validation/**/material_0.png

# Local editor/MCP config
.cursor/
toot.md
src/abstract3d.egg-info/

# Generated reference completion proof (current)
!artifacts/validation/generated-reference-completion/
artifacts/validation/generated-reference-completion/**/scene.obj

# Generated references v3 proof (adversarial rounds 1-2: completion-only
# protection, strict-only baking, person policy, whole-bake acceptance)
!artifacts/validation/generated-references-v3/


untracked
